# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas → Connect → Drivers → copy your connection string.
# Replace <password> with your database user password.
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Database name — must match what you see in Compass (e.g. heartdb). Collections: patients, users, otp
MONGODB_DB_NAME=heartdb

# Admin API (change in production)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password

# Comma-separated browser origins allowed to call this API (your deployed React URL).
# Example: https://myapp.netlify.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Windows only — path to tesseract.exe (optional; OCR disabled if unset on Linux)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata

# Server port (Render/Heroku set PORT automatically)
# PORT=5000
